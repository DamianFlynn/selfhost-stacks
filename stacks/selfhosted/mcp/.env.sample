# MCP Server Stack Configuration
# Model Context Protocol servers for AI agent integration

# ============================================================================
# Atlassian MCP (Jira + Confluence)
# ============================================================================
JIRA_URL=https://yourcompany.atlassian.net
JIRA_USERNAME=your.email@company.com
JIRA_API_TOKEN=your_jira_api_token_here

CONFLUENCE_URL=https://yourcompany.atlassian.net/wiki
CONFLUENCE_USERNAME=your.email@company.com
CONFLUENCE_API_TOKEN=your_confluence_api_token_here

# Note: Jira and Confluence often use the same API token
# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens

# ============================================================================
# Notion MCP
# ============================================================================
NOTION_API_KEY=ntn_your_notion_integration_token

# Generate at: https://www.notion.so/my-integrations
# Create an internal integration and copy the token

# ============================================================================
# D365 Finance & Operations MCP
# ============================================================================
D365FO_BASE_URL=https://yourorg.operations.dynamics.com/
D365FO_TENANT_ID=your-azure-tenant-id
D365FO_CLIENT_ID=your-azure-app-client-id
D365FO_CLIENT_SECRET=your-azure-app-client-secret
D365FO_LOG_LEVEL=INFO

# Azure AD App Registration required
# Grant permissions to D365 F&O APIs
# Tenant ID: Found in Azure AD properties
# Client ID/Secret: From App Registration

# ============================================================================
# MCP Transport Notes
# ============================================================================
# MCP servers can run in different transport modes:
# - stdio: Standard input/output (for VS Code, direct agent invocation)
# - SSE: Server-Sent Events over HTTP (for web-based agents)
# 
# This compose setup runs them as persistent services.
# For stdio mode, invoke via: docker exec -i mcp-atlassian [command]
# For HTTP/SSE mode, check individual MCP server documentation
