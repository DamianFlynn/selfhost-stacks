# Books Stack Environment Variables
# Copy to .env and fill in your values

########################### BOOKLORE
# Database
BOOKLORE_POSTGRES_DB=booklore
BOOKLORE_POSTGRES_USER=booklore
BOOKLORE_POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD_HERE_CHANGE_ME

# Security
BOOKLORE_SESSION_SECRET=YOUR_SESSION_SECRET_HERE_CHANGE_ME_32_CHARS

# Time zone
TZ=America/New_York
