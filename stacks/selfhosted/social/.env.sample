# Social Stack Environment Variables
# Copy to .env and fill in your values

########################### POSTIZ
# Database
DATABASE_URL=postgresql://postiz:YOUR_POSTGRES_PASSWORD@postiz_postgres:5432/postiz
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD
POSTGRES_USER=postiz
POSTGRES_DB=postiz

# Redis
REDIS_URL=redis://postiz_redis:6379

# URLs
MAIN_URL=https://social.deercrest.info
FRONTEND_URL=https://social.deercrest.info
NEXT_PUBLIC_BACKEND_URL=https://social.deercrest.info
BACKEND_INTERNAL_URL=http://postiz:3000

# Security
JWT_SECRET=YOUR_JWT_SECRET_HERE_CHANGE_ME
IS_GENERAL=true
DISABLE_REGISTRATION=false

# Storage
STORAGE_PROVIDER=local
UPLOAD_DIRECTORY=/uploads
NEXT_PUBLIC_UPLOAD_DIRECTORY=/uploads

# Developer
NX_ADD_PLUGINS=false

# API Limits
API_LIMIT=10

########################### RYBBIT
# Database
RYBBIT_DATABASE_URL=postgresql://rybbit:YOUR_RYBBIT_POSTGRES_PASSWORD@rybbit_postgres:5432/rybbit
RYBBIT_POSTGRES_PASSWORD=YOUR_RYBBIT_POSTGRES_PASSWORD
RYBBIT_POSTGRES_USER=rybbit
RYBBIT_POSTGRES_DB=rybbit

# Session
RYBBIT_SESSION_SECRET=YOUR_SESSION_SECRET_HERE_CHANGE_ME

# Reddit API - Get from https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=YOUR_REDDIT_CLIENT_ID
REDDIT_CLIENT_SECRET=YOUR_REDDIT_CLIENT_SECRET

# Hugo Integration (optional)
HUGO_CONTENT_PATH=/hugo/content
HUGO_STATIC_PATH=/hugo/static
