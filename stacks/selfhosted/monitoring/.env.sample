# Monitoring Stack Environment Configuration
# Copy this file to .env and customize for your environment

# User/Group IDs (match your apps user)
PUID=568
PGID=568

# Timezone
TZ=Europe/Dublin

# Domain name for Traefik routing
DOMAINNAME=deercrest.info

# Appdata directory path
APPDATA_DIR=/mnt/fast/appdata

# Prometheus Configuration
# Retention period for metrics (default: 30 days)
PROMETHEUS_RETENTION=30d

# Grafana Configuration
# Default admin credentials (CHANGE THESE!)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Optional Grafana plugins (comma-separated)
# Example: grafana-piechart-panel,grafana-clock-panel
GRAFANA_PLUGINS=
