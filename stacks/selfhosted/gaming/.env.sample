# Gaming Stack Environment Variables
# Copy to .env and fill in your values

########################### ROMM
# Database
ROMM_DB_NAME=romm
ROMM_DB_USER=romm
ROMM_DB_PASSWORD=YOUR_DB_PASSWORD_HERE_CHANGE_ME
ROMM_DB_ROOT_PASSWORD=YOUR_ROOT_PASSWORD_HERE_CHANGE_ME

# IGDB API (get from https://api.igdb.com/)
IGDB_CLIENT_ID=YOUR_IGDB_CLIENT_ID
IGDB_CLIENT_SECRET=YOUR_IGDB_CLIENT_SECRET

# Security
ROMM_AUTH_SECRET_KEY=YOUR_SECRET_KEY_HERE_CHANGE_ME_32_CHARS
ROMM_AUTH_ENABLED=true

# Time zone
TZ=America/New_York
