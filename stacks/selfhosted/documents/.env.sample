# Documents Stack Environment Variables
# Copy to .env and fill in your values

########################### PAPERLESS-NGX
# Database
PAPERLESS_DBNAME=paperless
PAPERLESS_DBUSER=paperless
PAPERLESS_DBPASS=YOUR_POSTGRES_PASSWORD_HERE_CHANGE_ME

# Security
PAPERLESS_SECRET_KEY=YOUR_SECRET_KEY_HERE_CHANGE_ME_MINIMUM_32_CHARS

# Admin account
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=YOUR_ADMIN_PASSWORD_HERE_CHANGE_ME
PAPERLESS_ADMIN_MAIL=admin@deercrest.info

# OCR Languages (space-separated ISO 639-2 codes)
# Common: eng (English), fra (French), deu (German), spa (Spanish)
PAPERLESS_OCR_LANGUAGE=eng
PAPERLESS_OCR_LANGUAGES=eng fra deu spa

# Time zone
TZ=America/New_York

########################### PAPERLESS-GPT
# Paperless API
PAPERLESS_GPT_API_TOKEN=YOUR_PAPERLESS_API_TOKEN_FROM_SETTINGS

# OpenAI Configuration
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Use local LLM (OpenClaw on Cerebro VM)
# OPENAI_BASE_URL=http://172.16.1.160:11434/v1
# OPENAI_MODEL=llama3
# OPENAI_API_KEY=not-needed-for-local

# AI Features
PAPERLESS_GPT_AUTO_TAG=true
PAPERLESS_GPT_AUTO_CORRESPONDENT=true
PAPERLESS_GPT_AUTO_DOCUMENT_TYPE=true
PAPERLESS_GPT_INTERVAL=300
