# MPE ERPNext (frappe_docker) Configuration — copy to .env (gitignored).
# Consumed by the upstream frappe_docker compose files + compose.override.yaml.

# Pin ERPNext to v16 (GA; latest stable at authoring = v16.22.0).
ERPNEXT_VERSION=v16.22.0

# Compose project name — all MPE ERPNext containers get this prefix.
COMPOSE_PROJECT_NAME=mpe-erpnext

# MariaDB root password (used by bench new-site --mariadb-root-password).
#   openssl rand -base64 24
DB_PASSWORD=

# ERPNext Administrator password for the new site.
#   openssl rand -base64 24
ADMIN_PASSWORD=

# Internal bench site id (kept stable). Public URL is mpe-erp.diginerve.net —
# FRAPPE_SITE_NAME_HEADER below forces the frontend to serve this site regardless
# of the request Host, so the public hostname and the site id can differ.
SITE_NAME=mpe.diginerve.net

# frappe_docker frontend routing — fixed to the site id so the right site is served.
FRAPPE_SITE_NAME_HEADER=mpe.diginerve.net

# Internal service wiring (frappe_docker defaults; leave unless you know better).
DB_HOST=db
DB_PORT=3306
REDIS_CACHE=redis-cache:6379
REDIS_QUEUE=redis-queue:6379
SOCKETIO_PORT=9000

# No host HTTP port published — ingress is via Traefik + the tunnel.
# (frappe_docker's HTTP_PUBLISH_PORT is intentionally unset.)
