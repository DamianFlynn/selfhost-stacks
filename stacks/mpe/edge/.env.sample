# MPE Edge Stack Configuration — copy to .env (gitignored) and fill in.

# Timezone
TZ=Europe/Dublin

# Cloudflare Tunnel token (remotely-managed tunnel).
# Emitted by scripts/setup-mpe-cloudflare.sh or the Cloudflare dashboard when the
# "mpe" tunnel is created. Connects this LXC outbound to the Cloudflare edge.
# DO NOT COMMIT.
TUNNEL_TOKEN=
