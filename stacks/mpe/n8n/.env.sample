# MPE n8n Stack Configuration — copy to .env (gitignored) and fill in.

# Base domain (flat naming — host derives as mpe-n8n.${DOMAINNAME}).
DOMAINNAME=diginerve.net
TZ=Europe/Dublin

# Generate once and keep stable — losing it makes stored credentials undecryptable.
#   openssl rand -hex 32
N8N_ENCRYPTION_KEY=

# Postgres password for the MPE n8n DB.
#   openssl rand -base64 24
N8N_DB_PASSWORD=
